# gimpo365-inventory 환경변수 예시
# 이 파일을 .env 로 복사한 뒤 값을 채운다.  (TECH_SPEC §15.3)
# .env 는 절대 커밋하지 않는다.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
# 쉼표로 구분. 원내 네트워크(LAN) 테스트로 다른 PC 에서 접속하려면
# 서버 PC 의 내부 IP(ipconfig 의 IPv4 주소)를 추가한다. (OPERATIONS_SETUP §1A)
# 예: DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.0.25
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (SQLite 사용 금지 - TECH_SPEC §0)
POSTGRES_DB=gimpo365os_rehearsal
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# 알파테스트 종료 시 운영기록 초기화(reset_alpha_transactions)를 일시적으로 허용합니다.
# 정식 운영 중에는 반드시 false로 유지합니다. (P3-08A-01)
# 실제 리셋 1회 실행 시에만 true로 바꾸고, 실행 후 즉시 false로 되돌린 뒤 프로세스를 재시작합니다.
ALLOW_ALPHA_TRANSACTION_RESET=false
